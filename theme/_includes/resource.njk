---
layout: main.njk
---
{% set resources = collections.all | filterAttribute("type", "Resource") %}
{% set prerequisiteReferences = prerequisite_reference | resolveResourceReferences(resources) %}
{% set nextResources = resources | filterByReferencedPath("prerequisite_reference", page.url) | sort(attribute="data.title") %}

<article class="resource-page">
  <header class="resource-header">
    {% if track or format or level %}
      <p class="resource-kicker">
        {% if track %}<span>{{ track }}</span>{% endif %}
        {% if format %}<span>{{ format }}</span>{% endif %}
        {% if level %}<span>{{ level }}</span>{% endif %}
      </p>
    {% endif %}
    <h1>{{ title }}</h1>
    {% if description %}
      <p class="resource-lead">{{ description }}</p>
    {% endif %}

    {% if source_url %}
      <p class="resource-source-link">
        <a href="{{ source_url }}">Original Source</a>
      </p>
    {% endif %}
  </header>

  {% if prerequisiteReferences.length or nextResources.length %}
    <section class="resource-section resource-path">
      <h2>Learning Path</h2>
      <div class="resource-path-flow">
        <div class="resource-path-node">
          <p class="resource-path-label">Previous</p>
          {% if prerequisiteReferences.length %}
            <ul class="resource-path-list">
              {% for reference in prerequisiteReferences %}
                <li>
                  {% if reference.resource %}
                    <a href="{{ reference.resource.url }}">{{ reference.resource.data.title }}</a>
                  {% else %}
                    {{ reference.text | markdownPathLinks | safe }}
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <span class="resource-path-empty">No prerequisite resources</span>
          {% endif %}
        </div>

        <div class="resource-path-arrow" aria-hidden="true">&rarr;</div>

        <div class="resource-path-node is-current">
          <p class="resource-path-label">Current</p>
          <strong>{{ title }}</strong>
        </div>

        {% if nextResources.length %}
          <div class="resource-path-arrow" aria-hidden="true">&rarr;</div>
          <div class="resource-path-node">
            <p class="resource-path-label">Next</p>
            {% if nextResources.length == 1 %}
              <a href="{{ nextResources[0].url }}">{{ nextResources[0].data.title }}</a>
            {% else %}
              <span>{{ nextResources.length }} possible next resources</span>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if nextResources.length > 1 %}
        <div class="resource-path-next-list">
          <h3>Possible Next Resources</h3>
          <ul>
            {% for item in nextResources %}
              <li><a href="{{ item.url }}">{{ item.data.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </section>
  {% endif %}

  {% if author_source or version or license or prerequisiteReferences.length or software_version %}
    <details class="resource-disclosure resource-section" open>
      <summary>Metadata</summary>
      <div class="resource-disclosure-body">
        <dl class="resource-meta">
          {% if author_source %}
            <div>
              <dt>Author / Source</dt>
              <dd>{{ author_source }}</dd>
            </div>
          {% endif %}
          {% if version %}
            <div>
              <dt>Version / Updated</dt>
              <dd>{{ version }}</dd>
            </div>
          {% endif %}
          {% if license %}
            <div>
              <dt>License / Usage Rights</dt>
              <dd>{{ license }}</dd>
            </div>
          {% endif %}
          {% if prerequisiteReferences.length %}
            <div>
              <dt>Prerequisite Resources</dt>
              <dd>
                <ul class="resource-reference-list">
                  {% for reference in prerequisiteReferences %}
                    <li>
                      {% if reference.resource %}
                        <a href="{{ reference.resource.url }}">{{ reference.resource.data.title }}</a>
                      {% else %}
                        {{ reference.text | markdownPathLinks | safe }}
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </dd>
            </div>
          {% endif %}
          {% if software_version %}
            <div>
              <dt>Software + Version</dt>
              <dd>{{ software_version }}</dd>
            </div>
          {% endif %}
        </dl>
      </div>
    </details>
  {% endif %}

  {% if glossary_terms and glossary_terms.length or core_concepts or learning_goals or addons_plugins or assets_formats %}
    <details class="resource-disclosure resource-section">
      <summary>Learning Details</summary>
      <div class="resource-disclosure-body">
        {% if glossary_terms and glossary_terms.length %}
          <section class="resource-subsection">
            <h3>Key Terms</h3>
            <ul class="resource-terms">
              {% for term in glossary_terms %}
                <li>{{ term }}</li>
              {% endfor %}
            </ul>
          </section>
        {% endif %}

        {% if core_concepts %}
          <section class="resource-subsection">
            <h3>Core Concepts / Content</h3>
            {{ core_concepts | markdown | safe }}
          </section>
        {% endif %}

        {% if learning_goals %}
          <section class="resource-subsection">
            <h3>Learning Goals</h3>
            {{ learning_goals | markdown | safe }}
          </section>
        {% endif %}

        {% if addons_plugins %}
          <section class="resource-subsection">
            <h3>Required Add-ons / Plugins</h3>
            {{ addons_plugins | markdown | safe }}
          </section>
        {% endif %}

        {% if assets_formats %}
          <section class="resource-subsection">
            <h3>File Formats / Assets</h3>
            {{ assets_formats | markdown | safe }}
          </section>
        {% endif %}
      </div>
    </details>
  {% endif %}

  {% if content %}
    <details class="resource-disclosure resource-section">
      <summary>Resource Content</summary>
      <div class="resource-disclosure-body">
        {{ content | safe }}
      </div>
    </details>
  {% endif %}
</article>
