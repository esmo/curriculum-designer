---
layout: main.njk
---
<article class="resource-page">
  <header class="resource-header">
    {% if track or format or level %}
      <p class="resource-kicker">
        {% if track %}<span>{{ track }}</span>{% endif %}
        {% if format %}<span>{{ format }}</span>{% endif %}
        {% if level %}<span>{{ level }}</span>{% endif %}
      </p>
    {% endif %}
    <h1>{{ title }}</h1>
    {% if description %}
      <p class="resource-lead">{{ description }}</p>
    {% endif %}
  </header>

  {% if author_source or source_url or version or license or prerequisite_reference or software_version %}
    <dl class="resource-meta">
      {% if author_source %}
        <div>
          <dt>Author / Source</dt>
          <dd>{{ author_source }}</dd>
        </div>
      {% endif %}
      {% if source_url %}
        <div>
          <dt>Original Source</dt>
          <dd><a href="{{ source_url }}">{{ source_url }}</a></dd>
        </div>
      {% endif %}
      {% if version %}
        <div>
          <dt>Version / Updated</dt>
          <dd>{{ version }}</dd>
        </div>
      {% endif %}
      {% if license %}
        <div>
          <dt>License / Usage Rights</dt>
          <dd>{{ license }}</dd>
        </div>
      {% endif %}
      {% if prerequisite_reference %}
        <div>
          <dt>Prerequisite Resource</dt>
          <dd>{{ prerequisite_reference }}</dd>
        </div>
      {% endif %}
      {% if software_version %}
        <div>
          <dt>Software + Version</dt>
          <dd>{{ software_version }}</dd>
        </div>
      {% endif %}
    </dl>
  {% endif %}

  {% if glossary_terms and glossary_terms.length %}
    <section class="resource-section">
      <h2>Key Terms</h2>
      <ul class="resource-terms">
        {% for term in glossary_terms %}
          <li>{{ term }}</li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% if core_concepts %}
    <section class="resource-section">
      <h2>Core Concepts / Content</h2>
      {{ core_concepts | markdown | safe }}
    </section>
  {% endif %}

  {% if learning_goals %}
    <section class="resource-section">
      <h2>Learning Goals</h2>
      {{ learning_goals | markdown | safe }}
    </section>
  {% endif %}

  {% if addons_plugins %}
    <section class="resource-section">
      <h2>Required Add-ons / Plugins</h2>
      {{ addons_plugins | markdown | safe }}
    </section>
  {% endif %}

  {% if assets_formats %}
    <section class="resource-section">
      <h2>File Formats / Assets</h2>
      {{ assets_formats | markdown | safe }}
    </section>
  {% endif %}

  {% if content %}
    <section class="resource-section">
      {{ content | safe }}
    </section>
  {% endif %}
</article>
