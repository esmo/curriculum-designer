<main class="admin-page">
  <section class="admin-card">
    <header class="admin-card-header">
      <p class="admin-eyebrow">Admin Workspace</p>
      <h1 class="admin-page-title">Curriculum Admin</h1>
      <p class="admin-page-intro">
        Creates or updates entries in <code>content/</code> (or
        <code>$BLENDER_CURRICULUM_CONTENT_ROOT</code>) and then starts an Eleventy build.
      </p>
    </header>

    <section id="login-panel" class="admin-auth admin-panel" hidden>
      <div class="admin-panel-header">
        <h2>Sign In</h2>
        <p class="hint admin-panel-intro">
          Sign in to create, edit, or delete entries.
        </p>
      </div>
      <form id="login-form" class="admin-auth-form" autocomplete="on">
        <div class="admin-grid-2 admin-auth-fields">
          <label>
            Username
            <input id="login-username" name="username" type="text" autocomplete="username" required />
          </label>

          <label>
            Password
            <input id="login-password" name="password" type="password" autocomplete="current-password" required />
          </label>
        </div>

        <div class="actions">
          <button id="login-btn" type="submit">Sign In</button>
          <div id="login-status" class="status"></div>
        </div>
      </form>
    </section>

    <section id="editor-panel" class="admin-editor admin-panel" hidden>
      <div class="admin-session-row">
        <div class="admin-session-copy">
          <span class="admin-session-label">Session</span>
          <span>Signed in as <strong id="session-user-name"></strong></span>
        </div>
        <button id="logout-btn" type="button" class="secondary">Sign Out</button>
      </div>

      <form id="entry-form" class="admin-form">
        <div class="admin-grid-2 admin-form-head">
          <label>
            Type
            <select id="entry-type" name="entryType" required></select>
          </label>

          <p class="hint admin-schema-hint">
            Fields are loaded from YAML schemas and written directly into Markdown files.
          </p>
        </div>

        <div id="fields-root" class="fields-grid"></div>

        <label class="checkbox admin-check-card">
          <input type="checkbox" name="overwrite" />
          <span>Overwrite an existing file with the same slug</span>
        </label>

        <div class="actions admin-form-actions">
          <button id="submit-btn" type="submit">Save</button>
          <button id="delete-btn" class="danger" type="button" hidden>Delete</button>
          <div id="status" class="status"></div>
        </div>
      </form>
    </section>
  </section>
</main>

<script>
  (() => {
    const loginPanel = document.getElementById("login-panel");
    const editorPanel = document.getElementById("editor-panel");
    const loginForm = document.getElementById("login-form");
    const loginStatusEl = document.getElementById("login-status");
    const loginBtn = document.getElementById("login-btn");
    const logoutBtn = document.getElementById("logout-btn");
    const sessionUserNameEl = document.getElementById("session-user-name");

    const form = document.getElementById("entry-form");
    const statusEl = document.getElementById("status");
    const submitBtn = document.getElementById("submit-btn");
    const deleteBtn = document.getElementById("delete-btn");
    const entryTypeSelect = document.getElementById("entry-type");
    const fieldsRoot = document.getElementById("fields-root");
    const overwriteCheckbox = form.querySelector('input[name="overwrite"]');
    const overwriteLabel = overwriteCheckbox?.closest(".checkbox");

    const urlParams = new URLSearchParams(window.location.search);
    const requestedEntryType = sanitizeEntryType(urlParams.get("entryType"));
    const requestedSlug = slugify(urlParams.get("slug"));
    const isEditMode = Boolean(requestedEntryType && requestedSlug);
    const editTarget = isEditMode
      ? { entryType: requestedEntryType, slug: requestedSlug }
      : null;

    let slugWasEdited = false;
    let schemaMap = new Map();
    let currentSchema = null;
    let editorInitialized = false;
    let markdownEditors = new Map();

    function slugify(value) {
      return String(value || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9_-]+/g, "-")
        .replace(/^[-_]+|[-_]+$/g, "");
    }

    function sanitizeEntryType(value) {
      return String(value || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9_-]+/g, "-")
        .replace(/^-+|-+$/g, "");
    }

    function setStatusElement(element, message, type) {
      if (!element) {
        return;
      }

      element.className = "status";
      if (type) {
        element.classList.add(type);
      }
      element.textContent = message || "";
    }

    function setStatus(message, type) {
      setStatusElement(statusEl, message, type);
    }

    function setLoginStatus(message, type) {
      setStatusElement(loginStatusEl, message, type);
    }

    function syncGlobalAuthUi(loggedIn, userName) {
      const userNameEl = document.querySelector("[data-user-name]");
      const editLink = document.querySelector("[data-admin-edit-link]");
      const loginLink = document.querySelector("[data-admin-login-link]");
      const createLink = document.querySelector("[data-admin-create-link]");

      if (loginLink) {
        loginLink.classList.toggle("is-hidden", loggedIn);
      }

      if (editLink) {
        editLink.classList.toggle("is-hidden", !loggedIn);
      }

      if (createLink) {
        createLink.classList.toggle("is-hidden", !loggedIn);
      }

      if (userNameEl) {
        userNameEl.hidden = !loggedIn;
        userNameEl.textContent = loggedIn ? userName : "";
      }
    }

    function setPanelState(loggedIn, userName) {
      const isLoggedIn = Boolean(loggedIn);
      const normalizedUserName = String(userName || "").trim();

      if (loginPanel) {
        loginPanel.hidden = isLoggedIn;
      }

      if (editorPanel) {
        editorPanel.hidden = !isLoggedIn;
      }

      if (sessionUserNameEl) {
        sessionUserNameEl.textContent = isLoggedIn ? normalizedUserName : "";
      }

      syncGlobalAuthUi(isLoggedIn, normalizedUserName);

      if (!isLoggedIn && loginForm) {
        loginForm.reset();
      }
    }

    async function fetchJson(url, options = {}) {
      const response = await fetch(url, {
        credentials: "same-origin",
        ...options,
      });

      let data = null;
      try {
        data = await response.json();
      } catch (_) {
        data = null;
      }

      return {
        response,
        data,
      };
    }

    async function readSession() {
      const { response, data } = await fetchJson("/admin/session");
      if (!response.ok) {
        return {
          loggedIn: false,
          userName: "",
        };
      }

      const userName = String(data?.user?.name || "").trim();
      return {
        loggedIn: Boolean(data?.loggedIn) || userName.length > 0,
        userName,
      };
    }

    function createTextAreaControl(field, elementId) {
      const textarea = document.createElement("textarea");
      textarea.id = elementId;
      textarea.name = field.name;
      if (field.rows) {
        textarea.rows = field.rows;
      }
      if (field.placeholder) {
        textarea.placeholder = field.placeholder;
      }
      if (field.input === "markdown" || field.name === "content") {
        textarea.style.minHeight = "360px";
      } else if (field.name === "description") {
        textarea.style.minHeight = "100px";
      }
      return textarea;
    }

    function fieldInputElement(field, elementId) {
      if (field.input === "textarea" || field.input === "markdown") {
        return createTextAreaControl(field, elementId);
      }

      if (field.input === "select") {
        const select = document.createElement("select");
        select.id = elementId;
        select.name = field.name;
        for (const option of field.options || []) {
          const opt = document.createElement("option");
          opt.value = option.value;
          opt.textContent = option.label;
          select.appendChild(opt);
        }
        return select;
      }

      const input = document.createElement("input");
      input.id = elementId;
      input.name = field.name;
      input.type = field.input === "number" ? "number" : "text";
      if (field.input === "number" && Number.isFinite(field.min)) {
        input.min = String(field.min);
      }
      if (field.placeholder) {
        input.placeholder = field.placeholder;
      }
      return input;
    }

    function createMarkdownCommands() {
      return [
        "bold",
        "italic",
        "strikethrough",
        "|",
        "code",
        "|",
        "h1",
        "h2",
        "|",
        "ul",
        "ol",
        "|",
        "blockquote",
        "hr",
        "|",
        "insertLink",
      ];
    }

    function createField(field) {
      const elementId = `field-${field.name}`;
      const wrapper = document.createElement("div");
      wrapper.className = [
        "field",
        `width-${field.width || "full"}`,
        `field-kind-${field.input || "text"}`,
        `field-name-${field.name}`,
        field.required ? "is-required" : "",
      ]
        .filter(Boolean)
        .join(" ");

      const header = document.createElement("span");
      header.className = "field-header";

      const title = document.createElement("span");
      title.className = "field-title";
      title.textContent = field.label;
      header.appendChild(title);

      if (field.required) {
        const badge = document.createElement("span");
        badge.className = "field-badge";
        badge.textContent = "Required";
        header.appendChild(badge);
      }

      wrapper.appendChild(header);

      const control = fieldInputElement(field, elementId);
      control.dataset.fieldName = field.name;
      control.required = field.required === true && field.input !== "markdown";
      if (field.required === true && field.input === "markdown") {
        control.dataset.required = "true";
      }

      if (field.input === "markdown") {
        const shell = document.createElement("div");
        shell.className = "admin-markdown-shell";

        const toolbarRow = document.createElement("div");
        toolbarRow.className = "admin-markdown-toolbar";

        const commandBar = document.createElement("div");
        commandBar.className = "admin-markdown-commandbar";
        toolbarRow.appendChild(commandBar);

        const previewButton = document.createElement("button");
        previewButton.type = "button";
        previewButton.className = "secondary admin-markdown-preview-toggle";
        previewButton.dataset.fieldName = field.name;
        previewButton.textContent = "Preview";
        toolbarRow.appendChild(previewButton);

        const stage = document.createElement("div");
        stage.className = "admin-markdown-stage";
        if (field.name === "content") {
          stage.classList.add("is-tall");
        }
        stage.appendChild(control);

        const previewPanel = document.createElement("div");
        previewPanel.className = "admin-markdown-preview";
        previewPanel.dataset.fieldName = field.name;
        previewPanel.hidden = true;

        shell.appendChild(toolbarRow);
        shell.appendChild(stage);
        shell.appendChild(previewPanel);
        wrapper.appendChild(shell);
      } else {
        wrapper.appendChild(control);
      }

      if (field.hint) {
        const hint = document.createElement("span");
        hint.className = "hint";
        hint.textContent = field.hint;
        wrapper.appendChild(hint);
      }

      return wrapper;
    }

    function getFieldElement(fieldName) {
      return fieldsRoot.querySelector(`[data-field-name="${fieldName}"]`);
    }

    function getMarkdownEditorEntry(fieldName) {
      return markdownEditors.get(fieldName) || null;
    }

    function setMarkdownPreviewButtonState(entry) {
      if (!entry?.previewButton) {
        return;
      }

      entry.previewButton.textContent = entry.previewVisible ? "Hide Preview" : "Preview";
      entry.previewButton.classList.toggle("is-active", entry.previewVisible);
    }

    async function requestMarkdownPreview(fieldName) {
      const entry = getMarkdownEditorEntry(fieldName);
      if (!entry || !entry.previewVisible || !entry.previewPanel) {
        return;
      }

      entry.previewRequestId += 1;
      const requestId = entry.previewRequestId;
      entry.previewPanel.innerHTML =
        '<p class="admin-markdown-preview-status">Rendering preview...</p>';

      const { response, data } = await fetchJson("/admin/api/preview", {
        method: "POST",
        headers: {
          "content-type": "application/json",
        },
        body: JSON.stringify({
          markdown: entry.editor.getContent(),
        }),
      });

      const latestEntry = getMarkdownEditorEntry(fieldName);
      if (!latestEntry || latestEntry.previewRequestId !== requestId) {
        return;
      }

      if (!response.ok) {
        latestEntry.previewPanel.innerHTML = `<p class="admin-markdown-preview-status is-error">${String(
          data?.error || "Preview could not be rendered."
        )}</p>`;
        return;
      }

      const html = String(data?.html || "").trim();
      latestEntry.previewPanel.innerHTML = html
        ? html
        : '<p class="admin-markdown-preview-status">Preview is empty.</p>';
    }

    function scheduleMarkdownPreview(fieldName, delayMs = 160) {
      const entry = getMarkdownEditorEntry(fieldName);
      if (!entry || !entry.previewVisible) {
        return;
      }

      if (entry.previewTimer) {
        window.clearTimeout(entry.previewTimer);
      }

      entry.previewTimer = window.setTimeout(() => {
        entry.previewTimer = 0;
        requestMarkdownPreview(fieldName).catch((error) => {
          const latestEntry = getMarkdownEditorEntry(fieldName);
          if (!latestEntry?.previewPanel) {
            return;
          }

          latestEntry.previewPanel.innerHTML = `<p class="admin-markdown-preview-status is-error">${String(
            error?.message || "Preview could not be rendered."
          )}</p>`;
        });
      }, delayMs);
    }

    async function toggleMarkdownPreview(fieldName) {
      const entry = getMarkdownEditorEntry(fieldName);
      if (!entry || !entry.previewPanel) {
        return;
      }

      entry.previewVisible = !entry.previewVisible;
      entry.previewPanel.hidden = !entry.previewVisible;
      setMarkdownPreviewButtonState(entry);

      if (!entry.previewVisible) {
        if (entry.previewTimer) {
          window.clearTimeout(entry.previewTimer);
          entry.previewTimer = 0;
        }
        return;
      }

      await requestMarkdownPreview(fieldName);
    }

    function destroyMarkdownEditors() {
      // TinyMDE currently does not expose a destroy API.
      for (const entry of markdownEditors.values()) {
        if (entry.previewTimer) {
          window.clearTimeout(entry.previewTimer);
        }
      }
      markdownEditors = new Map();
    }

    function initializeMarkdownEditors() {
      for (const field of currentSchema?.fields || []) {
        if (field.input !== "markdown") {
          continue;
        }

        if (
          typeof window.TinyMDE?.Editor !== "function" ||
          typeof window.TinyMDE?.CommandBar !== "function"
        ) {
          throw new Error("Markdown editor could not be loaded.");
        }

        const textarea = getFieldElement(field.name);
        if (!textarea) {
          continue;
        }

        const shell = textarea.closest(".admin-markdown-shell");
        const commandBarElement = shell?.querySelector(".admin-markdown-commandbar");
        const previewButton = shell?.querySelector(".admin-markdown-preview-toggle");
        const previewPanel = shell?.querySelector(".admin-markdown-preview");

        if (!commandBarElement || !previewButton || !previewPanel) {
          continue;
        }

        const editor = new window.TinyMDE.Editor({
          textarea,
          placeholder: field.placeholder || "",
        });

        const commandBar = new window.TinyMDE.CommandBar({
          element: commandBarElement,
          editor,
          commands: createMarkdownCommands(),
        });

        const entry = {
          editor,
          commandBar,
          textarea,
          previewButton,
          previewPanel,
          previewVisible: false,
          previewTimer: 0,
          previewRequestId: 0,
        };

        previewButton.addEventListener("click", () => {
          toggleMarkdownPreview(field.name).catch((error) => {
            previewPanel.innerHTML = `<p class="admin-markdown-preview-status is-error">${String(
              error?.message || "Preview could not be rendered."
            )}</p>`;
          });
        });

        editor.addEventListener("change", () => {
          if (entry.previewVisible) {
            scheduleMarkdownPreview(field.name);
          }
        });

        setMarkdownPreviewButtonState(entry);
        markdownEditors.set(field.name, entry);
      }
    }

    function connectSlugAutofill() {
      if (isEditMode) {
        slugWasEdited = true;
        return;
      }

      slugWasEdited = false;
      const titleInput = getFieldElement("title");
      const slugInput = getFieldElement("slug");
      if (!titleInput || !slugInput) {
        return;
      }

      titleInput.addEventListener("input", () => {
        if (!slugWasEdited) {
          slugInput.value = slugify(titleInput.value);
        }
      });

      slugInput.addEventListener("input", () => {
        slugWasEdited = slugInput.value.trim().length > 0;
      });
    }

    function validateMarkdownRequiredFields() {
      for (const field of currentSchema?.fields || []) {
        if (field.input !== "markdown" || field.required !== true) {
          continue;
        }

        const input = getFieldElement(field.name);
        if (!input) {
          continue;
        }

        const value = readFieldValue(field, input).trim();
        if (value.length > 0) {
          continue;
        }

        getMarkdownEditorEntry(field.name)?.editor?.e?.focus();
        throw new Error(`${field.label} is required.`);
      }
    }

    function renderSchema(schema) {
      destroyMarkdownEditors();
      currentSchema = schema;
      fieldsRoot.innerHTML = "";
      for (const field of schema.fields || []) {
        fieldsRoot.appendChild(createField(field));
      }
      initializeMarkdownEditors();
      connectSlugAutofill();
    }

    function setFieldValue(field, input, value) {
      const normalizedValue = value === null || value === undefined ? "" : String(value);
      if (field.input === "markdown") {
        const entry = getMarkdownEditorEntry(field.name);
        if (entry?.editor) {
          entry.editor.setContent(normalizedValue);
          if (entry.previewVisible) {
            scheduleMarkdownPreview(field.name, 0);
          }
          return;
        }
      }

      input.value = normalizedValue;
    }

    function applyFieldValues(values) {
      for (const field of currentSchema?.fields || []) {
        const input = getFieldElement(field.name);
        if (!input) {
          continue;
        }

        setFieldValue(field, input, values[field.name]);
      }
    }

    function readFieldValue(field, input) {
      if (field.input === "markdown") {
        const entry = getMarkdownEditorEntry(field.name);
        if (entry?.editor) {
          return entry.editor.getContent();
        }
      }

      return String(input.value || "");
    }

    function buildDeployMessage(data, mode) {
      const sync = data.build?.sync;
      let buildText = "Build completed successfully.";
      let statusType = "success";

      if (!data.build?.ok) {
        buildText = `${mode} was saved, but the build failed.`;
        statusType = "error";
      } else if (sync && !sync.ok && !sync.skipped) {
        buildText =
          "Build completed successfully, but syncing to BLENDER_CURRICULUM_WEB_ROOT failed.";
        statusType = "error";
      } else if (sync && sync.ok && !sync.skipped) {
        buildText = "Build and sync completed successfully.";
      } else if (sync && sync.skipped) {
        buildText =
          "Build completed successfully (no BLENDER_CURRICULUM_WEB_ROOT sync configured).";
      }

      return {
        text: buildText,
        statusType,
      };
    }

    function throwIfUnauthorized(response) {
      if (response.status === 401) {
        throw new Error("Not signed in. Please sign in again.");
      }
    }

    async function loadEntryForEdit(entryType, slug) {
      const { response, data } = await fetchJson(
        `/admin/api/entries/${encodeURIComponent(entryType)}/${encodeURIComponent(slug)}`
      );
      throwIfUnauthorized(response);

      if (!response.ok || !data?.ok) {
        throw new Error(data?.error || "Entry could not be loaded.");
      }

      if (!schemaMap.has(data.entryType)) {
        throw new Error(`Schema "${data.entryType}" is not available.`);
      }

      if (entryTypeSelect.value !== data.entryType) {
        entryTypeSelect.value = data.entryType;
        renderSchema(schemaMap.get(data.entryType));
      }

      applyFieldValues(data.fields || {});

      const slugInput = getFieldElement("slug");
      if (slugInput) {
        slugInput.value = data.slug || slug;
        slugInput.readOnly = true;
      }

      submitBtn.textContent = "Save";
      if (overwriteCheckbox) {
        overwriteCheckbox.checked = true;
      }
      if (overwriteLabel) {
        overwriteLabel.hidden = true;
      }

      entryTypeSelect.disabled = true;
      deleteBtn.hidden = false;
      setStatus(`Editing: ${data.file}`, null);
    }

    async function loadSchemas() {
      const { response, data } = await fetchJson("/admin/api/schemas");
      throwIfUnauthorized(response);

      if (!response.ok || !data?.ok) {
        throw new Error(data?.error || "Schemas could not be loaded.");
      }

      entryTypeSelect.innerHTML = "";
      schemaMap = new Map();

      for (const schema of data.schemas || []) {
        schemaMap.set(schema.id, schema);
        const option = document.createElement("option");
        option.value = schema.id;
        option.textContent = schema.label;
        entryTypeSelect.appendChild(option);
      }

      const initialType = data.defaultEntryType || entryTypeSelect.value;
      if (!schemaMap.has(initialType)) {
        throw new Error("No valid default schema found.");
      }

      entryTypeSelect.value = initialType;
      renderSchema(schemaMap.get(initialType));
    }

    function payloadFromForm() {
      if (!currentSchema) {
        throw new Error("No active schema loaded.");
      }

      validateMarkdownRequiredFields();

      const fields = {};
      for (const field of currentSchema.fields || []) {
        const input = getFieldElement(field.name);
        if (!input) {
          continue;
        }

        if (field.input === "number") {
          const raw = String(input.value || "").trim();
          fields[field.name] = raw === "" ? null : Number(raw);
        } else {
          fields[field.name] = readFieldValue(field, input);
        }
      }

      if ((!fields.slug || fields.slug.trim() === "") && fields.title) {
        fields.slug = slugify(fields.title);
        const slugInput = getFieldElement("slug");
        if (slugInput) {
          slugInput.value = fields.slug;
        }
      }

      if (isEditMode && editTarget) {
        fields.slug = editTarget.slug;
      }

      const overwrite = isEditMode
        ? true
        : new FormData(form).get("overwrite") === "on";

      return {
        entryType: entryTypeSelect.value,
        fields,
        overwrite,
      };
    }

    entryTypeSelect.addEventListener("change", () => {
      if (isEditMode) {
        return;
      }

      const schema = schemaMap.get(entryTypeSelect.value);
      if (schema) {
        renderSchema(schema);
      }
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      setStatus("Saving...", null);
      submitBtn.disabled = true;

      try {
        const payload = payloadFromForm();
        const { response, data } = await fetchJson("/admin/api/entries", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });
        throwIfUnauthorized(response);

        if (!response.ok || !data?.ok) {
          throw new Error(data?.error || "Unknown error");
        }

        const deployMessage = buildDeployMessage(data, "Entry");
        const shouldRedirect = data.deployOk === true;

        if (shouldRedirect) {
          setStatus(
            `Saved: ${data.file}. ${deployMessage.text} Redirecting...`,
            deployMessage.statusType
          );
        } else {
          setStatus(`Saved: ${data.file}. ${deployMessage.text}`, deployMessage.statusType);
        }

        if (shouldRedirect && data.viewUrl) {
          setTimeout(() => {
            window.location.assign(data.viewUrl);
          }, 300);
        }
      } catch (error) {
        setStatus(error.message, "error");
      } finally {
        submitBtn.disabled = false;
      }
    });

    deleteBtn.addEventListener("click", async () => {
      if (!isEditMode || !editTarget) {
        return;
      }

      const confirmed = window.confirm(
        `Do you really want to delete "${editTarget.slug}"?`
      );
      if (!confirmed) {
        return;
      }

      setStatus("Deleting...", null);
      submitBtn.disabled = true;
      deleteBtn.disabled = true;

      try {
        const { response, data } = await fetchJson(
          `/admin/api/entries/${encodeURIComponent(editTarget.entryType)}/${encodeURIComponent(editTarget.slug)}`,
          {
            method: "DELETE",
          }
        );
        throwIfUnauthorized(response);

        if (!response.ok || !data?.ok) {
          throw new Error(data?.error || "Delete failed.");
        }

        const deployMessage = buildDeployMessage(data, "Entry");
        const shouldRedirect = data.deployOk === true;

        if (shouldRedirect) {
          setStatus(
            `Deleted: ${data.file}. ${deployMessage.text} Redirecting...`,
            deployMessage.statusType
          );
        } else {
          setStatus(`Deleted: ${data.file}. ${deployMessage.text}`, deployMessage.statusType);
        }

        if (shouldRedirect && data.listUrl) {
          setTimeout(() => {
            window.location.assign(data.listUrl);
          }, 300);
        }
      } catch (error) {
        setStatus(error.message, "error");
      } finally {
        submitBtn.disabled = false;
        deleteBtn.disabled = false;
      }
    });

    loginForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      setLoginStatus("Signing in...", null);
      loginBtn.disabled = true;

      try {
        const formData = new FormData(loginForm);
        const username = String(formData.get("username") || "").trim();
        const password = String(formData.get("password") || "");

        const { response, data } = await fetchJson("/admin/login", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify({
            username,
            password,
          }),
        });

        if (!response.ok || !data?.ok) {
          throw new Error(data?.error || "Sign-in failed.");
        }

        setLoginStatus("Signed in successfully.", "success");
        await bootstrap();
      } catch (error) {
        setLoginStatus(error.message, "error");
      } finally {
        loginBtn.disabled = false;
      }
    });

    logoutBtn.addEventListener("click", async () => {
      logoutBtn.disabled = true;
      setStatus("");

      try {
        await fetchJson("/admin/logout", {
          method: "POST",
        });
      } finally {
        logoutBtn.disabled = false;
      }

      await bootstrap();
    });

    async function initializeEditor() {
      if (editorInitialized) {
        return;
      }

      editorInitialized = true;
      await loadSchemas();

      if (!isEditMode || !editTarget) {
        return;
      }

      if (!schemaMap.has(editTarget.entryType)) {
        throw new Error(`Unknown entryType "${editTarget.entryType}" in the URL.`);
      }

      entryTypeSelect.value = editTarget.entryType;
      renderSchema(schemaMap.get(editTarget.entryType));
      await loadEntryForEdit(editTarget.entryType, editTarget.slug);
    }

    async function bootstrap() {
      setStatus("");
      const session = await readSession();
      if (!session.loggedIn) {
        setPanelState(false, "");
        return;
      }

      setPanelState(true, session.userName);
      try {
        await initializeEditor();
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    bootstrap().catch((error) => {
      setPanelState(false, "");
      setLoginStatus(error.message || "Session could not be loaded.", "error");
    });
  })();
</script>
