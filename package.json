{
  "scripts": {
    "build": "eleventy --input=src/ --output=build/",
    "clean": "shx rm -rf build_bac && shx mv build build_bac || true",
    "watch": "onchange 'src/**/*' -- npm-run-all clean build",
    "serve": "npm run build && browser-sync start --server build/ --files 'build/**/*' --no-notify",
    "start": "npm-run-all clean build --parallel watch serve"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "browser-sync": "^3.0.2",
    "markdown-it": "^14.1.0",
    "markdown-it-video": "^0.6.3",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "serve": "^14.2.1",
    "shx": "^0.3.4"
  }
}
